{
  "name": "@saas-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "20.20.1",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm nx build api-platform",
    "build:web": "pnpm nx build web-platform",
    "dev:web": "pnpm nx dev web-platform",
    "auth:token:local": "node tools/auth/generate-local-jwt.mjs",
    "install:sri:schema-bundle": "node tools/sri/install-sri-schema-bundle.mjs",
    "prepare:ec:pkcs12-env": "node tools/smoke/prepare-ec-pkcs12-env.mjs",
    "smoke:ec:issuer-alignment": "node tools/smoke/run-ec-issuer-alignment-smoke.mjs",
    "smoke:ec:sandbox-bootstrap": "node tools/smoke/run-ec-issuer-alignment-smoke.mjs --bootstrap-remote-sandbox",
    "smoke:ec:remote-submit": "node tools/smoke/run-ec-remote-submission-smoke.mjs",
    "smoke:ec:tax-compliance-operational": "node tools/smoke/run-ec-tax-compliance-operational-smoke.mjs",
    "smoke:ec:tax-compliance-closeout-6": "node tools/smoke/run-ec-tax-compliance-closeout-6-smoke.mjs",
    "smoke:accounting:foundation": "node tools/smoke/run-accounting-foundation-smoke.mjs",
    "smoke:medical-clinics:activation": "node tools/smoke/run-medical-clinics-activation-smoke.mjs",
    "smoke:ai:guarded-execution-growth-lane": "node tools/smoke/run-ai-guarded-execution-growth-lane-smoke.mjs",
    "smoke:ai:guarded-execution-rejection-fallback": "node tools/smoke/run-ai-guarded-execution-rejection-fallback-smoke.mjs",
    "smoke:ai:retrieval-fed-run": "node tools/smoke/run-ai-retrieval-fed-run-smoke.mjs",
    "smoke:ai:ecommerce-launch": "node tools/smoke/run-ai-ecommerce-launch-smoke.mjs",
    "smoke:ai:ecommerce-post-sale-closeout": "node tools/smoke/run-ai-ecommerce-post-sale-closeout-smoke.mjs",
    "smoke:ai:ecommerce-invoice-handoff": "node tools/smoke/run-ai-ecommerce-invoice-handoff-smoke.mjs",
    "smoke:ai:ecommerce-closeout": "node tools/smoke/run-ai-ecommerce-closeout-smoke-pack.mjs",
    "smoke:ai:clinics-assistant": "node tools/smoke/run-ai-clinics-assistant-smoke.mjs",
    "smoke:ai:guarded-execution-invoice-lane": "node tools/smoke/run-ai-guarded-execution-invoice-lane-smoke.mjs",
    "smoke:ai:guarded-execution-invoice-rejection-fallback": "node tools/smoke/run-ai-guarded-execution-invoice-rejection-fallback-smoke.mjs",
    "smoke:ai:closeout": "node tools/smoke/run-ai-closeout-smoke-pack.mjs",
    "design:validate:claude": "node tools/design/validate-claude-design-slices.mjs",
    "openapi:generate": "node tools/openapi/generate-openapi-contract.mjs",
    "openapi:check": "node tools/openapi/generate-openapi-contract.mjs && git diff --exit-code docs/api/openapi.json",
    "dev:whatsapp-monitor-collector": "node tools/observability/run-whatsapp-operational-monitor-collector.mjs",
    "smoke:growth:whatsapp-monitor-observability": "node tools/smoke/run-whatsapp-operational-monitor-observability-smoke.mjs",
    "smoke:growth:whatsapp-provider-taxonomy": "node tools/smoke/run-whatsapp-provider-taxonomy-smoke.mjs",
    "package:api": "pnpm nx build api-platform && pnpm nx run api-platform:prune",
    "test": "pnpm nx test api-platform-e2e",
    "check": "pnpm prisma:validate && pnpm build",
    "ci:verify": "pnpm prisma:generate && pnpm prisma:validate && pnpm build && pnpm test",
    "validate:sri:xsd": "pnpm validate:sri:xsd:invoice && pnpm validate:sri:xsd:credit-note && pnpm validate:sri:xsd:debit-note && pnpm validate:sri:xsd:remission-guide && pnpm validate:sri:xsd:withholding",
    "validate:sri:xsd:invoice": "xmllint --noout --schema \"vendor/sri/factura-2.1.0/XML y XSD Factura/factura_V2.1.0.xsd\" \"vendor/sri/factura-2.1.0/XML y XSD Factura/factura_V2.1.0.xml\"",
    "validate:sri:xsd:credit-note": "xmllint --noout --schema \"vendor/sri/nota-credito-1.0.0/XML y XSD Nota de Credito/notaCredito_V1.0.0.xsd\" \"vendor/sri/nota-credito-1.0.0/XML y XSD Nota de Credito/notaCredito_V1.0.0.xml\"",
    "validate:sri:xsd:debit-note": "xmllint --noout --schema \"vendor/sri/nota-debito-1.0.0/XML y XSD Nota de Debito/notaDebito_V1.0.0.xsd\" \"vendor/sri/nota-debito-1.0.0/XML y XSD Nota de Debito/notaDebito_V1.0.0.xml\"",
    "validate:sri:xsd:remission-guide": "xmllint --noout --schema \"vendor/sri/guia-remision-1.0.0/XML y XSD Guia de Remision/guiaRemision_V1.0.0.xsd\" \"vendor/sri/guia-remision-1.0.0/XML y XSD Guia de Remision/guiaRemision_V1.0.0.xml\"",
    "validate:sri:xsd:withholding": "xmllint --noout --schema \"vendor/sri/comprobante-retencion-2.0.0/XML y XSD Comprobante de Retencion/comprobanteRetencion_V2.0.0.xsd\" \"vendor/sri/comprobante-retencion-2.0.0/XML y XSD Comprobante de Retencion/comprobanteRetencion_V2.0.0.xml\"",
    "changeset": "changeset",
    "release:status": "changeset status --verbose",
    "release:version": "changeset version && pnpm install --no-frozen-lockfile",
    "release:tag": "changeset tag",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate"
  },
  "prisma": {
    "schema": "packages/infra/prisma/prisma/schema.prisma"
  },
  "private": true,
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/jest": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/nest": "^22.6.4",
    "@nx/node": "22.6.4",
    "@nx/react": "22.6.4",
    "@nx/vite": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/webpack": "22.6.4",
    "@nx/workspace": "22.6.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "~4.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.6.4",
    "prettier": "~3.6.2",
    "prisma": "5.22.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "5.22.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nodemailer": "^8.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  }
}

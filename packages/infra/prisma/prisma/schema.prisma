// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id
  email          String       @unique
  name           String?
  avatarUrl      String?
  authProvider   String
  externalAuthId String?
  preferredTenantId String?
  memberships    Membership[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Tenant {
  id          String       @id
  name        String
  slug        String       @unique
  status      String
  memberships Membership[]
  invitations Invitation[]
  subscriptions Subscription[]
  entitlements Entitlement[]
  featureFlags FeatureFlag[]
  customers    Customer[]
  taxRates     TaxRate[]
  invoices     Invoice[]
  invoiceElectronicEvents InvoiceElectronicEvent[]
  invoiceItems InvoiceItem[]
  payments     Payment[]
  electronicSubmissionSettings ElectronicSubmissionSettings?
  issuerProfile IssuerProfile?
  electronicSignatureSettings ElectronicSignatureSettings?
  invoiceNumberingSettings InvoiceNumberingSettings?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Customer {
  id        String   @id
  tenantId  String
  name      String
  email     String?
  taxId     String?
  identificationType String?
  identification String?
  billingAddress String?
  invoices  Invoice[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model Invoice {
  id         String   @id
  tenantId    String
  customerId String
  number     String
  documentCode String?
  establishmentCode String?
  emissionPointCode String?
  sequenceNumber Int?
  buyerIdentificationType String?
  buyerIdentification String?
  buyerName String?
  buyerAddress String?
  electronicStatus String?
  accessKey String?
  authorizationNumber String?
  authorizedAt DateTime?
  electronicStatusMessage String?
  signedAt DateTime?
  submittedAt DateTime?
  submissionReference String?
  status     String
  currency   String
  issuedAt   DateTime
  dueAt      DateTime?
  notes      String?
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  electronicEvents InvoiceElectronicEvent[]
  items      InvoiceItem[]
  payments   Payment[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([customerId])
}

model InvoiceElectronicEvent {
  id                  String   @id
  tenantId            String
  invoiceId           String
  eventType           String
  provider            String
  providerStatus      String
  endpoint            String?
  soapAction          String?
  message             String
  requestPayload      String?
  responsePayload     String?
  submissionReference String?
  authorizationNumber String?
  occurredAt          DateTime
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId, occurredAt])
  @@index([invoiceId, eventType, occurredAt])
}

model IssuerProfile {
  id                    String   @id
  tenantId              String   @unique
  legalName             String
  commercialName        String?
  taxId                 String
  environment           String
  emissionType          String
  accountingObligated   Boolean
  specialTaxpayerCode   String?
  rimpeTaxpayerType     String?
  matrixAddress         String
  establishmentAddress  String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ElectronicSignatureSettings {
  id                    String   @id
  tenantId              String   @unique
  provider              String
  certificateLabel      String
  storageMode           String
  certificateFingerprint String?
  pkcs12SecretRef       String?
  privateKeyPasswordSecretRef String?
  subjectName           String?
  isActive              Boolean  @default(true)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ElectronicSubmissionSettings {
  id                   String   @id
  tenantId             String   @unique
  provider             String
  environment          String
  transmissionMode     String
  receptionUrl         String?
  authorizationUrl     String?
  credentialsSecretRef String?
  timeoutMs            Int
  isActive             Boolean  @default(true)
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model InvoiceNumberingSettings {
  id                 String   @id
  tenantId           String   @unique
  documentCode       String
  establishmentCode  String
  emissionPointCode  String
  nextSequenceNumber Int
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model InvoiceItem {
  id               String   @id
  tenantId         String
  invoiceId        String
  position         Int
  description      String
  quantity         Int
  unitPriceInCents Int
  lineTotalInCents Int
  taxRateId        String?
  taxRateName      String?
  taxRatePercentage Float?
  lineTaxInCents   Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([invoiceId, position])
  @@index([tenantId, invoiceId, createdAt])
  @@index([tenantId, taxRateId])
}

model TaxRate {
  id         String   @id
  tenantId   String
  name       String
  percentage Float
  isActive   Boolean  @default(true)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model Payment {
  id            String   @id
  tenantId      String
  invoiceId     String
  amountInCents Int
  currency      String
  status        String
  method        String
  reference     String?
  paidAt        DateTime
  notes         String?
  reversedAt    DateTime?
  reversalReason String?
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, invoiceId, paidAt])
}

model Product {
  id              String           @id
  key             String           @unique
  name            String
  description     String?
  isActive        Boolean          @default(true)
  platformModules PlatformModule[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Plan {
  id               String            @id
  key              String            @unique
  name             String
  description      String?
  priceInCents     Int
  currency         String
  billingCycle     String
  isActive         Boolean           @default(true)
  planEntitlements PlanEntitlement[]
  subscriptions    Subscription[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model PlanEntitlement {
  id          String   @id
  planId      String
  key         String
  value       Json
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([planId, key])
}

model Subscription {
  id          String   @id
  tenantId     String   @unique
  planId      String
  status      String
  startedAt   DateTime
  expiresAt   DateTime?
  trialEndsAt DateTime?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Entitlement {
  id          String   @id
  tenantId    String
  key         String
  value       Json
  source      String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
}

model FeatureFlag {
  id          String   @id
  tenantId    String
  key         String
  enabled     Boolean
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
}

model PlatformModule {
  id          String   @id
  productId   String
  key         String
  name        String
  description String?
  isCore      Boolean  @default(false)
  isActive    Boolean  @default(true)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, key])
}

model Membership {
  id              String           @id
  tenantId        String
  userId          String
  status          String
  invitedBy       String?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([tenantId, userId])
}

model Invitation {
  id               String   @id
  tenantId         String
  email            String
  roleKey          String
  status           String
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, email, status])
}

model Role {
  id              String           @id
  key             String           @unique
  name            String
  scope           String
  membershipRoles MembershipRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model MembershipRole {
  id           String     @id
  membershipId String
  roleId       String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([membershipId, roleId])
}

model RolePermission {
  id           String     @id
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

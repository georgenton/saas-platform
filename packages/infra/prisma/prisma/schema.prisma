// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id
  email          String       @unique
  name           String?
  avatarUrl      String?
  authProvider   String
  externalAuthId String?
  preferredTenantId String?
  memberships    Membership[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Tenant {
  id          String       @id
  name        String
  slug        String       @unique
  status      String
  memberships Membership[]
  invitations Invitation[]
  subscriptions Subscription[]
  entitlements Entitlement[]
  featureFlags FeatureFlag[]
  leads        Lead[]
  opportunities Opportunity[]
  conversationThreads ConversationThread[]
  conversationMessages ConversationMessage[]
  conversationDeliveryEvents ConversationDeliveryEvent[]
  whatsappMessageTemplates WhatsappMessageTemplate[]
  whatsappAutomationRules WhatsappAutomationRule[]
  whatsappAutomationExecutions WhatsappAutomationExecution[]
  whatsappOperationalMonitorRuns WhatsappOperationalMonitorRun[]
  whatsappOperationalAlertAcknowledgements WhatsappOperationalAlertAcknowledgement[]
  growthOperationalCases GrowthOperationalCase[]
  growthOperationalCaseAutoAssignmentSettings GrowthOperationalCaseAutoAssignmentSettings?
  aiApprovalRequests AiApprovalRequest[]
  aiMemoryRecords  AiMemoryRecord[]
  aiSuggestionRuns AiSuggestionRun[]
  aiGuardedExecutionEvents AiGuardedExecutionEvent[]
  ecommerceProductDrafts EcommerceProductDraft[]
  ecommerceOrderDrafts EcommerceOrderDraft[]
  ecommerceProductSetups EcommerceProductSetup[]
  ecommerceProductEntityChannelDrafts EcommerceProductEntityChannelDraft[]
  ecommerceProductEntities EcommerceProductEntity[]
  webhookEventEnvelopes WebhookEventEnvelope[]
  customers    Customer[]
  taxRates     TaxRate[]
  invoices     Invoice[]
  invoiceElectronicEvents InvoiceElectronicEvent[]
  invoiceItems InvoiceItem[]
  payments     Payment[]
  electronicSubmissionSettings ElectronicSubmissionSettings?
  issuerProfile IssuerProfile?
  electronicSignatureSettings ElectronicSignatureSettings?
  invoiceNumberingSettings InvoiceNumberingSettings[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Lead {
  id           String   @id
  tenantId      String
  fullName     String
  email        String?
  phoneE164    String?
  whatsappE164 String?
  source       String
  status       String
  notes        String?
  opportunities Opportunity[]
  conversationThreads ConversationThread[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

model ConversationThread {
  id                   String   @id
  tenantId             String
  leadId               String?
  assigneeUserId       String?
  subject              String
  channel              String
  externalConversationId String?
  participantDisplayName String?
  participantHandle    String?
  status               String
  latestMessagePreview String?
  messageCount         Int      @default(0)
  openedAt             DateTime
  closedAt             DateTime?
  lastActivityAt       DateTime
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead                 Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunities        Opportunity[]
  messages             ConversationMessage[]
  automationExecutions WhatsappAutomationExecution[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, lastActivityAt])
  @@index([tenantId, leadId])
  @@index([tenantId, channel, lastActivityAt])
}

model ConversationMessage {
  id                String   @id
  tenantId          String
  threadId          String
  direction         String
  body              String
  templateId        String?
  retryOfMessageId  String?
  renderedTemplateSnapshotJson String? @db.Text
  outboundIntentKey String?
  provider          String?
  deliveryStatus    String?
  externalMessageId String?
  failureReason     String?
  deliveredAt       DateTime?
  readAt            DateTime?
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread            ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  template          WhatsappMessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  deliveryEvents    ConversationDeliveryEvent[]
  automationExecutions WhatsappAutomationExecution[] @relation("WhatsappAutomationExecutionOutputMessage")
  createdAt         DateTime @default(now())

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, externalMessageId])
  @@index([tenantId, retryOfMessageId])
}

model WhatsappMessageTemplate {
  id           String   @id
  tenantId     String
  key          String
  name         String
  languageCode String
  category     String
  bodyTemplate String
  intentKey    String?
  providerTemplateName String?
  providerApprovalStatus String
  status       String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages     ConversationMessage[]
  automationRules WhatsappAutomationRule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, createdAt])
  @@index([tenantId, intentKey])
}

model WhatsappAutomationRule {
  id                    String   @id
  tenantId              String
  key                   String
  name                  String
  triggerEvent          String
  matchOutboundIntentKey String?
  matchDeliveryStatus   String?
  matchAssigneeMode     String
  templateId            String?
  actionType            String
  actionOutboundIntentKey String?
  status                String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template              WhatsappMessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  executions            WhatsappAutomationExecution[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, triggerEvent])
}

model WhatsappAutomationExecution {
  id                    String   @id
  tenantId              String
  threadId              String
  ruleId                String
  triggerEvent          String
  triggerMessageId      String?
  triggerExternalMessageId String?
  triggerDeliveryStatus String?
  executionKey          String
  status                String
  reason                String?
  outputMessageId       String?
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread                ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  rule                  WhatsappAutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  outputMessage         ConversationMessage? @relation("WhatsappAutomationExecutionOutputMessage", fields: [outputMessageId], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now())

  @@unique([tenantId, executionKey])
  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, ruleId, createdAt])
}

model ConversationDeliveryEvent {
  id                String   @id
  tenantId          String
  messageId         String?
  provider          String
  eventKey          String
  providerEventId   String?
  externalMessageId String
  deliveryStatus    String
  failureReason     String?
  providerStatusDetail String?
  providerConversationCategory String?
  providerPricingCategory String?
  providerErrorCode String?
  payloadJson       String?
  occurredAt        DateTime
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message           ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  @@unique([tenantId, provider, eventKey])
  @@index([tenantId, providerEventId])
  @@index([tenantId, externalMessageId, occurredAt])
  @@index([tenantId, messageId, occurredAt])
}

model WhatsappOperationalMonitorRun {
  id                String   @id @default(cuid())
  tenantId          String
  triggerSource     String
  generatedAt       DateTime
  autoRunReadyRetriesEnabled Boolean
  overallStatus     String
  totalAlertCount   Int
  criticalAlertCount Int
  warningAlertCount Int
  operationalThresholdsJson String @db.Text
  operationalDashboardJson  String @db.Text
  operationalAlertsJson     String @db.Text
  retryRunnerExecuted Boolean
  retryRunnerSummaryJson String? @db.Text
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([tenantId, generatedAt])
  @@index([tenantId, createdAt])
}

model WhatsappOperationalAlertAcknowledgement {
  id                String   @id @default(cuid())
  tenantId          String
  alertKey          String
  title             String
  severity          String
  summary           String
  provider          String?
  failureClass      String?
  providerTaxonomyFamily String?
  providerTaxonomyDetail String?
  affectedMessageCount Int
  recommendedAction String
  lastSeenGeneratedAt DateTime?
  acknowledgedAt    DateTime
  acknowledgedByUserId String
  acknowledgedByEmail String?
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, alertKey])
  @@index([tenantId, acknowledgedAt])
}

model GrowthOperationalCase {
  id                String   @id @default(cuid())
  tenantId          String
  sourceKey         String
  caseType          String
  status            String
  priority          String
  title             String
  summary           String
  nextAction        String
  followUpState     String?
  routingPolicyKey  String
  threadId          String?
  alertKey          String?
  dueAt             DateTime?
  assignedUserId    String?
  assignedUserEmail String?
  createdByUserId   String
  createdByEmail    String?
  resolvedAt        DateTime?
  resolvedByUserId  String?
  resolvedByEmail   String?
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, sourceKey])
  @@index([tenantId, status, priority, updatedAt])
  @@index([tenantId, routingPolicyKey, status, updatedAt])
  @@index([tenantId, threadId, updatedAt])
  @@index([tenantId, dueAt])
}

model GrowthOperationalCaseAutoAssignmentSettings {
  id               String   @id
  tenantId         String   @unique
  defaultPolicyKey String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AiSuggestionRun {
  id                 String   @id @default(cuid())
  tenantId           String
  tenantSlug         String
  agentKey           String
  mode               String
  status             String
  surfaceKey         String
  sourceContractKey  String
  sourceGeneratedAt  DateTime
  promptPackKey      String
  promptPackVersion  String
  generatedAt        DateTime
  requestedByUserId  String
  requestedByEmail   String?
  summary            String
  suggestedOutputKeysJson String @db.Text
  envelopeJson       String @db.Text
  approvalRequests   AiApprovalRequest[]
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@index([tenantId, agentKey, createdAt])
  @@index([tenantId, surfaceKey, createdAt])
}

model AiMemoryRecord {
  id              String   @id @default(cuid())
  tenantId        String
  tenantSlug      String
  scope           String
  domainKey       String?
  agentKey        String?
  sourceKind      String
  freshness       String
  title           String
  summary         String
  detail          String   @db.Text
  tagsJson        String   @db.Text
  status          String
  createdByUserId String?
  createdByEmail  String?
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, scope, updatedAt])
  @@index([tenantId, domainKey, updatedAt])
  @@index([tenantId, agentKey, updatedAt])
}

model AiApprovalRequest {
  id               String   @id @default(cuid())
  tenantId         String
  tenantSlug       String
  agentKey         String
  policyKey        String
  scope            String
  suggestionRunId  String
  requestedByUserId String
  requestedByEmail String?
  rationale        String?  @db.Text
  summary          String
  status           String
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByEmail  String?
  reviewNote       String?  @db.Text
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  suggestionRun    AiSuggestionRun @relation(fields: [suggestionRunId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, agentKey, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([suggestionRunId, createdAt])
}

model AiGuardedExecutionEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenantSlug        String
  agentKey          String
  eventType         String
  approvalRequestId String
  suggestionRunId   String
  toolKey           String
  caseId            String
  safeFallbackMode  String?
  summary           String
  detail            String   @db.Text
  occurredAt        DateTime
  createdByUserId   String?
  createdByEmail    String?
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([tenantId, agentKey, occurredAt])
  @@index([tenantId, eventType, occurredAt])
  @@index([approvalRequestId, occurredAt])
}

model WebhookEventEnvelope {
  id                    String   @id
  tenantId              String
  provider              String
  channel               String
  eventKey              String
  providerEventId       String?
  payloadHash           String
  signatureHeader       String?
  objectType            String?
  externalAccountId     String?
  externalPhoneNumberId String?
  status                String
  replayCount           Int      @default(0)
  lastReplayedAt        DateTime?
  processedInboundMessages Int   @default(0)
  processedDeliveryEvents Int    @default(0)
  failureReason         String?
  payloadJson           String
  receivedAt            DateTime
  processedAt           DateTime?
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, provider, eventKey])
  @@index([tenantId, providerEventId])
  @@index([tenantId, channel, receivedAt])
  @@index([tenantId, status, receivedAt])
}

model Opportunity {
  id            String   @id
  tenantId      String
  leadId        String?
  threadId      String?
  assigneeUserId String?
  title         String
  stage         String
  amountInCents Int?
  currency      String?
  notes         String?
  closedAt      DateTime?
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  thread        ConversationThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, stage, updatedAt])
  @@index([tenantId, leadId])
  @@index([tenantId, threadId])
}

model Customer {
  id        String   @id
  tenantId  String
  name      String
  email     String?
  taxId     String?
  identificationType String?
  identification String?
  billingAddress String?
  invoices  Invoice[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model Invoice {
  id         String   @id
  tenantId    String
  customerId String
  number     String
  documentCode String?
  establishmentCode String?
  emissionPointCode String?
  sequenceNumber Int?
  modifiedDocumentId String?
  modifiedDocumentNumber String?
  modifiedDocumentIssuedAt DateTime?
  modificationReason String?
  shipmentReason String?
  shipmentStartAt DateTime?
  shipmentEndAt DateTime?
  departureAddress String?
  arrivalAddress String?
  carrierName String?
  carrierIdentificationType String?
  carrierIdentification String?
  vehiclePlate String?
  destinationRoute String?
  buyerIdentificationType String?
  buyerIdentification String?
  buyerName String?
  buyerAddress String?
  electronicStatus String?
  accessKey String?
  authorizationNumber String?
  authorizedAt DateTime?
  electronicStatusMessage String?
  signedAt DateTime?
  submittedAt DateTime?
  submissionReference String?
  status     String
  currency   String
  issuedAt   DateTime
  dueAt      DateTime?
  notes      String?
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  electronicEvents InvoiceElectronicEvent[]
  items      InvoiceItem[]
  payments   Payment[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([customerId])
}

model InvoiceElectronicEvent {
  id                  String   @id
  tenantId            String
  invoiceId           String
  eventType           String
  provider            String
  providerStatus      String
  endpoint            String?
  soapAction          String?
  message             String
  requestPayload      String?
  responsePayload     String?
  submissionReference String?
  authorizationNumber String?
  occurredAt          DateTime
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId, occurredAt])
  @@index([invoiceId, eventType, occurredAt])
}

model IssuerProfile {
  id                    String   @id
  tenantId              String   @unique
  legalName             String
  commercialName        String?
  taxId                 String
  environment           String
  emissionType          String
  accountingObligated   Boolean
  specialTaxpayerCode   String?
  rimpeTaxpayerType     String?
  matrixAddress         String
  establishmentAddress  String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ElectronicSignatureSettings {
  id                    String   @id
  tenantId              String   @unique
  provider              String
  certificateLabel      String
  storageMode           String
  certificateFingerprint String?
  pkcs12SecretRef       String?
  privateKeyPasswordSecretRef String?
  subjectName           String?
  isActive              Boolean  @default(true)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ElectronicSubmissionSettings {
  id                   String   @id
  tenantId             String   @unique
  provider             String
  environment          String
  transmissionMode     String
  receptionUrl         String?
  authorizationUrl     String?
  credentialsSecretRef String?
  timeoutMs            Int
  isActive             Boolean  @default(true)
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model InvoiceNumberingSettings {
  id                 String   @id
  tenantId           String
  documentCode       String
  establishmentCode  String
  emissionPointCode  String
  nextSequenceNumber Int
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, documentCode])
}

model InvoiceItem {
  id               String   @id
  tenantId         String
  invoiceId        String
  position         Int
  description      String
  quantity         Int
  unitPriceInCents Int
  lineTotalInCents Int
  taxRateId        String?
  taxRateName      String?
  taxRatePercentage Float?
  lineTaxInCents   Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([invoiceId, position])
  @@index([tenantId, invoiceId, createdAt])
  @@index([tenantId, taxRateId])
}

model TaxRate {
  id         String   @id
  tenantId   String
  name       String
  percentage Float
  isActive   Boolean  @default(true)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model Payment {
  id            String   @id
  tenantId      String
  invoiceId     String
  amountInCents Int
  currency      String
  status        String
  method        String
  reference     String?
  paidAt        DateTime
  notes         String?
  reversedAt    DateTime?
  reversalReason String?
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, invoiceId, paidAt])
}

model EcommerceProductDraft {
  id                       String   @id
  tenantId                 String
  tenantSlug               String
  sourceDraftId            String
  title                    String
  productType              String
  status                   String
  rationale                String
  suggestedChannelsJson    String   @db.Text
  briefingStatus           String?
  briefSummary             String?
  briefRequiredInputsJson  String   @db.Text
  briefGuardrailsJson      String   @db.Text
  refinementStatus         String?
  refinementSummary        String?
  pricingBand              String?
  offerAngle               String?
  primaryCta               String?
  channelSequenceJson      String   @db.Text
  refinementGuardrailsJson String   @db.Text
  promotedToWorkspaceAt    DateTime?
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([tenantId, sourceDraftId])
  @@index([tenantSlug, sourceDraftId])
  @@index([tenantId, createdAt])
}

model EcommerceOrderDraft {
  id                        String   @id
  tenantId                  String
  tenantSlug                String
  productEntityId           String
  status                    String
  orderLabel                String
  offerTitle                String
  pricingSnapshot           String
  primaryCta                String
  closingChannel            String
  captureStatus             String
  invoicingReadinessStatus  String
  customerProfileJson       String   @db.Text
  requiredFieldsJson        String   @db.Text
  optionalFieldsJson        String   @db.Text
  operatorPromptsJson       String   @db.Text
  missingFieldsJson         String   @db.Text
  blockedByJson             String   @db.Text
  guardrailsJson            String   @db.Text
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([tenantId, productEntityId])
  @@index([tenantSlug, productEntityId])
  @@index([tenantId, createdAt])
}

model EcommerceProductSetup {
  id                     String   @id
  tenantId               String
  tenantSlug             String
  savedDraftId           String
  sourceDraftId          String
  title                  String
  productType            String
  status                 String
  pricingBand            String?
  offerAngle             String?
  primaryCta             String?
  suggestedChannelsJson  String   @db.Text
  channelSequenceJson    String   @db.Text
  promotedFromWorkspaceAt DateTime
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([tenantId, savedDraftId])
  @@index([tenantSlug, savedDraftId])
  @@index([tenantId, createdAt])
}

model EcommerceProductEntity {
  id                    String   @id
  tenantId              String
  tenantSlug            String
  productSetupId        String
  savedDraftId          String
  sourceDraftId         String
  title                 String
  productType           String
  status                String
  pricingBand           String?
  offerAngle            String?
  primaryCta            String?
  suggestedChannelsJson String   @db.Text
  channelSequenceJson   String   @db.Text
  promotedFromSetupAt   DateTime
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, productSetupId])
  @@index([tenantSlug, productSetupId])
  @@index([tenantId, createdAt])
}

model EcommerceProductEntityChannelDraft {
  id                       String   @id
  tenantId                 String
  tenantSlug               String
  productEntityId          String
  channelKey               String
  status                   String
  preparationStatus        String
  handoffOwner             String
  title                    String
  summary                  String
  headline                 String
  draftBlueprintJson       String   @db.Text
  publishChecklistJson     String   @db.Text
  recommendedArtifactsJson String   @db.Text
  nextMilestone            String
  blockedByJson            String   @db.Text
  guardrailsJson           String   @db.Text
  promotedToAssetWorkspaceAt DateTime?
  promotedToAssetEntityAt  DateTime?
  promotedToReleaseCandidateAt DateTime?
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([tenantId, productEntityId, channelKey])
  @@index([tenantSlug, productEntityId])
  @@index([tenantId, createdAt])
}

model Product {
  id              String           @id
  key             String           @unique
  name            String
  description     String?
  isActive        Boolean          @default(true)
  platformModules PlatformModule[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Plan {
  id               String            @id
  key              String            @unique
  name             String
  description      String?
  priceInCents     Int
  currency         String
  billingCycle     String
  isActive         Boolean           @default(true)
  planEntitlements PlanEntitlement[]
  subscriptions    Subscription[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model PlanEntitlement {
  id          String   @id
  planId      String
  key         String
  value       Json
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([planId, key])
}

model Subscription {
  id          String   @id
  tenantId     String   @unique
  planId      String
  status      String
  startedAt   DateTime
  expiresAt   DateTime?
  trialEndsAt DateTime?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Entitlement {
  id          String   @id
  tenantId    String
  key         String
  value       Json
  source      String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
}

model FeatureFlag {
  id          String   @id
  tenantId    String
  key         String
  enabled     Boolean
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
}

model PlatformModule {
  id          String   @id
  productId   String
  key         String
  name        String
  description String?
  isCore      Boolean  @default(false)
  isActive    Boolean  @default(true)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, key])
}

model Membership {
  id              String           @id
  tenantId        String
  userId          String
  status          String
  invitedBy       String?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([tenantId, userId])
}

model Invitation {
  id               String   @id
  tenantId         String
  email            String
  roleKey          String
  status           String
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, email, status])
}

model Role {
  id              String           @id
  key             String           @unique
  name            String
  scope           String
  membershipRoles MembershipRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model MembershipRole {
  id           String     @id
  membershipId String
  roleId       String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([membershipId, roleId])
}

model RolePermission {
  id           String     @id
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@saas-platform/catalog-application": [
        "packages/core/catalog/application/src/index.ts"
      ],
      "@saas-platform/catalog-domain": [
        "packages/core/catalog/domain/src/index.ts"
      ],
      "@saas-platform/commercial-application": [
        "packages/core/commercial/application/src/index.ts"
      ],
      "@saas-platform/commercial-domain": [
        "packages/core/commercial/domain/src/index.ts"
      ],
      "@saas-platform/feature-flags-application": [
        "packages/core/feature-flags/application/src/index.ts"
      ],
      "@saas-platform/feature-flags-domain": [
        "packages/core/feature-flags/domain/src/index.ts"
      ],
      "@saas-platform/identity-application": [
        "packages/core/identity/application/src/index.ts"
      ],
      "@saas-platform/identity-domain": [
        "packages/core/identity/domain/src/index.ts"
      ],
      "@saas-platform/infra-prisma": [
        "packages/infra/prisma/src/index.ts"
      ],
      "@saas-platform/tenancy-application": [
        "packages/core/tenancy/application/src/index.ts"
      ],
      "@saas-platform/tenancy-domain": [
        "packages/core/tenancy/domain/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
